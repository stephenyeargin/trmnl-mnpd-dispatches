{% template dispatch_table %}
    <table class="table table--xsmall lg:table--condensed" data-table-limit="true">
      <thead>
        <tr>
          {%- unless is_condensed %}
          <th style="width:5%">
            <span class="title title--small lg:title--base">&nbsp;</span>
          </th>
          {%- endunless %}
          <th>
            <span class="title title--small lg:title--base">Description</span>
          </th>
          <th style="width:15%" class="text--center">
            <span class="title title--small lg:title--base">Received</span>
          </th>
          {%- unless is_condensed %}
          <th>
            <span class="title title--small lg:title--base">Location</span>
          </th>
          {%- endunless %}
          <th>
            <span class="title title--small lg:title--base">Zone</span>
          </th>
        </tr>
      </thead>
      <tbody>
        {% for row in features %}
        <tr>
          {%- unless is_condensed %}
          <td><span class="description description--base lg:description--large">{{ row.attributes.IncidentTypeCode }}</span></td>
          {%- endunless %}
          <td><span class="description description--base lg:description--large" data-clamp="1">{{ row.attributes.IncidentTypeName }}</span></td>
          <td class="text--center">
            <span class="description--base lg:description--large">
            {%- if row.attributes.CallReceivedTime %}
            {{ row.attributes.CallReceivedTime | divided_by: 1000 | date: "%s" | plus: trmnl.user.utc_offset | date: '%l:%M %p' }}
            {%- else %}
            Unknown
            {%- endif%}
            </span>
          </td>
          {%- unless is_condensed %}
          <td><span class="description description--base lg:description--large data-clamp="1"">{{ row.attributes.Location }}</span></td>
          {%- endunless %}
          <td><span class="description description--base lg:description--large data-clamp="1"">{{ row.attributes.CityName }}</span></td>
        </tr>
        {% else %}
        <tr>
          <td colspan="5" class="title title--base lg:title--large py--40 text--center">No active incidents</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
{% endtemplate %}
